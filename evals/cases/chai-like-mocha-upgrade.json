{
  "name": "chai-like mocha upgrade",
  "target": "../chai-like",
  "timeout": 1800,
  "env": {},
  "setup": [],
  "command": [
    "uv",
    "run",
    "upgrade-dependencies-agent",
    "upgrade",
    "{workdir}",
    "mocha 4 -> 11",
    "--report-json",
    "agent-report.json"
  ],
  "teardown": [],
  "budgets": {
    "max_iterations": 40,
    "max_tool_calls": 140,
    "max_input_tokens": 1000000,
    "max_output_tokens": 250000,
    "max_wall_time_seconds": 1800,
    "max_compaction_count": 4
  },
  "checks": [
    {
      "type": "package_json_version",
      "dependency": "mocha",
      "section": "devDependencies",
      "specifier": ">=11.0.0"
    },
    {
      "type": "command",
      "command": "npm test",
      "timeout": 300
    },
    {
      "type": "git_diff",
      "allowed_paths": [
        "package.json",
        "package-lock.json"
      ]
    },
    {
      "type": "structured_report",
      "path": "agent-report.json",
      "ok": true,
      "allowed_changed_files": [
        "package.json",
        "package-lock.json"
      ],
      "allow_remaining_risks": false
    }
  ]
}
