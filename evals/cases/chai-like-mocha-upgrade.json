{
  "name": "chai-like mocha upgrade",
  "target": "../chai-like",
  "timeout": 1800,
  "env": {},
  "setup": [],
  "command": [
    "uv",
    "run",
    "upgrade-dependencies-agent",
    "upgrade",
    "{workdir}",
    "mocha 4 -> 11"
  ],
  "teardown": [],
  "budgets": {
    "max_iterations": 40,
    "max_input_tokens": 1000000
  },
  "checks": [
    {
      "type": "package_json_version",
      "dependency": "mocha",
      "section": "devDependencies",
      "specifier": ">=11.0.0"
    },
    {
      "type": "command",
      "command": "npm test",
      "timeout": 300
    },
    {
      "type": "git_diff",
      "allowed_paths": [
        "package.json",
        "package-lock.json"
      ]
    }
  ]
}
