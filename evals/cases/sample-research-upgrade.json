{
  "name": "sample mocha research upgrade",
  "target": "../target-project",
  "timeout": 1800,
  "env": {},
  "setup": [],
  "command": [
    "uv",
    "run",
    "upgrade-dependencies-agent",
    "research-upgrade",
    "{workdir}",
    "mocha 4 -> 11"
  ],
  "teardown": [],
  "budgets": {
    "max_iterations": 20,
    "max_tool_calls": 80,
    "max_input_tokens": 500000,
    "max_output_tokens": 120000,
    "max_wall_time_seconds": 1800,
    "max_compaction_count": 2
  },
  "checks": [
    {
      "type": "git_diff",
      "allowed_paths": []
    }
  ]
}
