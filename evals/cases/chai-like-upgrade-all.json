{
  "name": "chai-like upgrade all direct dependencies",
  "target": "../chai-like",
  "timeout": 3600,
  "env": {},
  "setup": [],
  "command": [
    "uv",
    "run",
    "upgrade-dependencies-agent",
    "upgrade-all",
    "{workdir}"
  ],
  "teardown": [],
  "budgets": {
    "max_iterations": 80,
    "max_input_tokens": 2000000
  },
  "checks": [
    {
      "type": "command",
      "command": "npm test",
      "timeout": 300
    }
  ]
}
