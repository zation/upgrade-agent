{
  "name": "sample upgrade all direct dependencies",
  "target": "../target-project",
  "timeout": 3600,
  "env": {},
  "setup": [],
  "command": [
    "uv",
    "run",
    "upgrade-dependencies-agent",
    "upgrade-all",
    "{workdir}",
    "--report-json",
    "agent-report.json"
  ],
  "teardown": [],
  "budgets": {
    "max_iterations": 80,
    "max_tool_calls": 280,
    "max_input_tokens": 2000000,
    "max_output_tokens": 500000,
    "max_wall_time_seconds": 3600,
    "max_compaction_count": 8
  },
  "checks": [
    {
      "type": "command",
      "command": "npm test",
      "timeout": 300
    },
    {
      "type": "structured_report",
      "path": "agent-report.json",
      "ok": true,
      "allowed_changed_files": [
        "package.json",
        "package-lock.json"
      ],
      "allow_remaining_risks": false
    }
  ]
}
