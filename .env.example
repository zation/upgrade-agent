# --- Provider selection ---
# Set to "anthropic" (default) or "openai-compat" (DeepSeek, Ollama, vLLM, …)
LLM_PROVIDER=deepseek

# --- Anthropic (when LLM_PROVIDER=anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# --- OpenAI-compatible (when LLM_PROVIDER=openai-compat) ---
# Required: your API key for the provider.
LLM_API_KEY=sk-your-deepseek-key
# Optional: override the base URL (default: https://api.deepseek.com)
# LLM_BASE_URL=https://api.deepseek.com
# Optional: override the default model (default: deepseek-chat)
# LLM_MODEL=deepseek-chat
